{
    "name": "minject",
    "version": "1.0.0",
    "description": "A SOLID-compliant Dependency Injection library for Node.js",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "type": "module",
    "scripts": {
        "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
        "dev": "tsc -p tsconfig.dev.json && tsc-alias -p tsconfig.dev.json",
        "test": "vitest",
        "format": "prettier --write ."
    },
    "keywords": [
        "di",
        "dependency-injection",
        "ioc",
        "typescript",
        "solid"
    ],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "reflect-metadata": "^0.2.2"
    },
    "devDependencies": {
        "@types/node": "^20.11.0",
        "prettier": "^3.8.1",
        "ts-node": "^10.9.2",
        "tsc-alias": "^1.8.16",
        "typescript": "^5.3.3",
        "vitest": "^1.2.0"
    }
}
